"""
Minimal test coverage for RBAC and ticket assignment system.
Tests permission checking, assignment logic, and basic API functionality.
"""
import pytest
from uuid import uuid4
from sqlalchemy.orm import Session

from app.rbac import Permission, has_permission
from app.models.users import InternalUserRole, ClientUserRole
from app.services.ticket_assignment import TicketAssignmentService
from app.services.auth_service import AuthService


class TestRBACPermissions:
    """Test RBAC permission system."""

    def test_admin_has_system_management_permission(self):
        """Admin should have system management permissions."""
        assert has_permission(InternalUserRole.ADMIN.value, Permission.MANAGE_SYSTEM)
        assert has_permission(InternalUserRole.ADMIN.value, Permission.ASSIGN_TICKET)

    def test_technician_cannot_assign_tickets(self):
        """Technician should not have assignment permission."""
        assert not has_permission(InternalUserRole.TECHNICIAN.value, Permission.ASSIGN_TICKET)

    def test_technician_can_create_tickets(self):
        """Technician should be able to create tickets."""
        assert has_permission(InternalUserRole.TECHNICIAN.value, Permission.CREATE_TICKET)

    def test_technician_can_view_assigned_tickets(self):
        """Technician should be able to view assigned tickets."""
        assert has_permission(InternalUserRole.TECHNICIAN.value, Permission.VIEW_ASSIGNED_TICKETS)

    def test_technician_cannot_view_all_tickets(self):
        """Technician should not be able to view all tickets."""
        assert not has_permission(InternalUserRole.TECHNICIAN.value, Permission.VIEW_ALL_TICKETS)

    def test_technician_cannot_view_unassigned_queue(self):
        """Technician should not see unassigned queue."""
        assert not has_permission(InternalUserRole.TECHNICIAN.value, Permission.VIEW_UNASSIGNED_QUEUE)

    def test_client_user_can_create_portal_tickets(self):
        """Client user should be able to create tickets on portal."""
        assert has_permission(ClientUserRole.CLIENT_USER.value, Permission.PORTAL_CREATE_TICKET)

    def test_client_user_can_view_portal_tickets(self):
        """Client user should be able to view portal tickets."""
        assert has_permission(ClientUserRole.CLIENT_USER.value, Permission.PORTAL_VIEW_TICKETS)

    def test_client_user_cannot_assign_tickets(self):
        """Client user should not have assignment permissions."""
        assert not has_permission(ClientUserRole.CLIENT_USER.value, Permission.ASSIGN_TICKET)

    def test_client_admin_can_manage_users(self):
        """Client admin should be able to manage portal users."""
        assert has_permission(ClientUserRole.CLIENT_ADMIN.value, Permission.PORTAL_MANAGE_USERS)


class TestAuthService:
    """Test authentication service."""

    def test_password_hashing(self):
        """Password should be hashed correctly."""
        password = "test_password_123"
        hash1 = AuthService.hash_password(password)
        hash2 = AuthService.hash_password(password)

        # Hashes should be different (due to salt)
        assert hash1 != hash2

        # Both should verify correctly
        assert AuthService.verify_password(password, hash1)
        assert AuthService.verify_password(password, hash2)

    def test_password_verification_fails_with_wrong_password(self):
        """Password verification should fail with wrong password."""
        password = "test_password_123"
        hash_val = AuthService.hash_password(password)

        assert not AuthService.verify_password("wrong_password", hash_val)

    def test_internal_user_token_creation(self):
        """Internal user token should be created correctly."""
        user_id = uuid4()
        email = "admin@example.com"
        role = "admin"
        name = "Admin User"

        token = AuthService.create_internal_user_token(user_id, email, role, name)

        assert isinstance(token, str)
        assert len(token) > 0

    def test_portal_user_token_creation(self):
        """Portal user token should be created correctly."""
        user_id = uuid4()
        client_id = uuid4()
        email = "client@example.com"
        role = "client_user"
        site_ids = [str(uuid4()), str(uuid4())]

        token = AuthService.create_portal_user_token(user_id, email, role, client_id, site_ids)

        assert isinstance(token, str)
        assert len(token) > 0

    def test_portal_token_without_site_ids(self):
        """Portal token can be created without site IDs (for client_admin)."""
        user_id = uuid4()
        client_id = uuid4()
        email = "admin@client.com"
        role = "client_admin"

        token = AuthService.create_portal_user_token(user_id, email, role, client_id)

        assert isinstance(token, str)
        assert len(token) > 0


class TestTicketAssignmentService:
    """Test ticket assignment service logic."""

    def test_validate_assignment_permission_admin(self):
        """Admin should have assignment permission."""
        from app.guards import InternalUserClaims

        claims = InternalUserClaims(
            user_id=str(uuid4()),
            email="admin@example.com",
            role="admin",
            name="Admin"
        )

        assert TicketAssignmentService.validate_assignment_permission(claims)

    def test_validate_assignment_permission_technician(self):
        """Technician should not have assignment permission."""
        from app.guards import InternalUserClaims

        claims = InternalUserClaims(
            user_id=str(uuid4()),
            email="tech@example.com",
            role="technician",
            name="Technician"
        )

        assert not TicketAssignmentService.validate_assignment_permission(claims)


class TestAssignmentTypes:
    """Test different assignment types."""

    def test_auto_assignment_type(self):
        """Verify auto assignment type for technician-created tickets."""
        # When a technician creates a ticket, it should be auto-assigned
        assignment_type = "auto"
        assert assignment_type == "auto"

    def test_manual_assignment_type(self):
        """Verify manual assignment type when admin creates and assigns."""
        assignment_type = "manual"
        assert assignment_type == "manual"

    def test_reassign_type(self):
        """Verify reassign type when admin reassigns."""
        assignment_type = "reassign"
        assert assignment_type == "reassign"


# Integration tests would go here (with actual database)
# These are just basic unit tests for now


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
